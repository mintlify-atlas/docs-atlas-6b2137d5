  "keyFeatures": [
    "Neo4j-based knowledge graph for infrastructure relationships",
    "Natural language queries via Google Gemini LLM",
    "Pluggable connectors for Docker Compose, Kubernetes, and Teams",
    "Impact analysis with blast radius calculations",
    "Graph traversal for upstream and downstream dependencies",
    "Team ownership tracking and asset management"
  ],
  "publicApiSurface": [
    "POST /api/query - Process natural language queries",
    "GET /api/entities - Get available entities for autocomplete",
    "POST /api/reload - Reload configuration data",
    "GET /api/health - System health check",
    "QueryEngine.downstream() - Get transitive dependencies",
    "QueryEngine.upstream() - Get transitive dependents",
    "QueryEngine.blast_radius() - Full impact analysis",
    "QueryEngine.path() - Find shortest path between nodes",
    "QueryEngine.get_owner() - Find team ownership",
    "QueryEngine.get_team_assets() - Get team-owned assets",
    "BaseConnector.parse() - Parse configuration files",
    "GeminiLLM.parse_query_intent() - Parse natural language to structured queries"
  ]
}
